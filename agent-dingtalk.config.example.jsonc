{
  // Copy this file to agent-dingtalk.config.jsonc and replace the DingTalk credentials.
  "dingtalk": {
    "clientId": "dingxxxxxxxxxxxxxxxx",
    "clientSecret": "replace-with-dingtalk-client-secret",
    "robotCode": "dingbotxxxxxxxx",
    "allowedUserIds": ["replace-with-your-dingtalk-user-id"],
    "rejectGroupMessages": true
  },
  "defaultEnvironment": {
    "backend": "claude-code",
    "cwd": ".",
    "agent": "default",
    "model": "sonnet"
  },
  "projects": [
    {
      "name": "my-claw",
      "backend": "claude-code",
      "cwd": ".",
      "agent": "default",
      "model": "sonnet"
    }
  ],
  "security": {
    "allowedRootDirs": ["."],
    "downloadAllowedDirs": ["."],
    "maxDownloadFileBytes": 20971520,
    "attachmentTempDir": ".agent-dingtalk-tmp",
    "maxAttachmentFileBytes": 20971520,
    "allowedAttachmentMimeTypes": [
      "text/plain",
      "text/markdown",
      "text/csv",
      "application/json",
      "application/pdf",
      "image/png",
      "image/jpeg",
      "image/gif",
      "image/webp"
    ]
  },
  "claudeCode": {
    "permissionMode": "acceptEdits",
    "allowedTools": ["Read", "Edit", "Write", "Glob", "Grep", "Bash"],
    "maxTurns": 20
  },
  "output": {
    "mode": "markdown",
    "maxMessageChars": 18000,
    // Periodically flush new Agent output while a task runs, instead of only replying at the end.
    // Value is the minimum interval in milliseconds between progress replies (default 60000 = 1 min).
    // Set to 0 to disable and reply only once the task finishes.
    "progressIntervalMs": 60000
  },
  "streaming": {
    // Keep "markdown" unless you have created and published a DingTalk AI Card template.
    // Set to "ai-card" to stream long Agent output through DingTalk AI Card updates.
    "mode": "markdown",
    "templateId": "replace-with-dingtalk-ai-card-template-id",
    "updateThrottleMs": 800,
    "fallbackMode": "markdown",
    "contentKey": "content"
  }
}

{
  // Copy this file to agent-dingtalk.config.jsonc and replace the DingTalk credentials.
  "dingtalk": {
    "clientId": "dingxxxxxxxxxxxxxxxx",
    "clientSecret": "replace-with-dingtalk-client-secret",
    "robotCode": "dingbotxxxxxxxx",
    "allowedUserIds": ["replace-with-your-dingtalk-user-id"],
    "rejectGroupMessages": true
  },
  "defaultEnvironment": {
    "backend": "claude-code",
    "cwd": ".",
    "agent": "default",
    "model": "sonnet"
  },
  "projects": [
    {
      "name": "my-claw",
      "backend": "claude-code",
      "cwd": ".",
      "agent": "default",
      "model": "sonnet"
    }
  ],
  "security": {
    "allowedRootDirs": ["."],
    "downloadAllowedDirs": ["."],
    "maxDownloadFileBytes": 20971520,
    "attachmentTempDir": ".agent-dingtalk-tmp",
    "maxAttachmentFileBytes": 20971520,
    "allowedAttachmentMimeTypes": [
      "text/plain",
      "text/markdown",
      "text/csv",
      "application/json",
      "application/pdf",
      "image/png",
      "image/jpeg",
      "image/gif",
      "image/webp"
    ]
  },
  "claudeCode": {
    "permissionMode": "acceptEdits",
    "allowedTools": ["Read", "Edit", "Write", "Glob", "Grep", "Bash"],
    "maxTurns": 20
  },
  // Optional: Agent Client Protocol (ACP) backend. Required only when an
  // environment uses "backend": "acp". Define one or more named providers; each
  // "command" + "args" launches a compatible ACP agent as a stdio subprocess in
  // the selected working directory, and "env" adds environment variables merged
  // over the current process environment. Select a provider with
  // /acp <provider> [dir]; "defaultProvider" is used when the command omits one.
  // "acp": {
  //   "defaultProvider": "cc",
  //   "providers": {
  //     "cc": { "command": "claude-agent-acp", "args": [] },
  //     "cx": { "command": "codex-acp", "args": [] },
  //     "kimi": { "command": "kimi", "args": ["acp"] },
  //     "oc": { "command": "opencode", "args": ["acp"] }
  //   }
  // },
  "output": {
    "mode": "markdown",
    "maxMessageChars": 18000,
    // Periodically flush new Agent output while a task runs, instead of only replying at the end.
    // Value is the minimum interval in milliseconds between progress replies (default 60000 = 1 min).
    // Set to 0 to disable and reply only once the task finishes.
    "progressIntervalMs": 60000
  },
  "streaming": {
    // Keep "markdown" unless you have created and published a DingTalk AI Card template.
    // Set to "ai-card" to stream long Agent output through DingTalk AI Card updates.
    "mode": "markdown",
    "templateId": "replace-with-dingtalk-ai-card-template-id",
    "updateThrottleMs": 800,
    "fallbackMode": "markdown",
    "contentKey": "content"
  }
  // Optional: override the /screenshot capture command.
  // Omit this block to auto-detect a platform-appropriate command:
  //   macOS -> screencapture
  //   Linux -> the first available of gnome-screenshot / spectacle / grim / scrot / maim / import
  // The literal {output} token in "args" is replaced with the target PNG path;
  // if "args" omits {output}, the path is appended as the final argument.
  // "screenshot": {
  //   "command": "spectacle",
  //   "args": ["-b", "-n", "-o", "{output}"]
  // }
}
